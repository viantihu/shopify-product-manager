# LLM provider config for the AI Description Formatter.
# Copy this file to `.env` and fill in your real key. `.env` is gitignored.

# Which provider/model the formatter uses. Swappable without code changes.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8

# Your Anthropic API key (get one at https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-your-key-here
